NODE_ENV=development
PORT=3000
# Docker Compose maps host ports when local 5432/6379/9000 are busy:
# postgres 45432, redis 46379, minio 49000/49001, api 43000
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=audio
DATABASE_PASSWORD=audio
DATABASE_NAME=audio_service
REDIS_HOST=localhost
REDIS_PORT=6379
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_ORIGINALS=audio-originals
MINIO_BUCKET_DERIVATIVES=audio-derivatives
MINIO_BUCKET_ARTIFACTS=audio-artifacts
# Leave empty to use PATH
FFMPEG_PATH=
FFPROBE_PATH=
FFMPEG_CONCURRENCY=
FFMPEG_TIMEOUT_MS=600000
MAX_UPLOAD_MB=2048
PRESIGN_TTL_SEC=3600
MINIO_BUCKET_SAMPLES=piano-samples
